{
  "extends": "./tsconfig.node-esm.json",
  "compilerOptions": {
    "declaration": false,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/templates/**"]
}
